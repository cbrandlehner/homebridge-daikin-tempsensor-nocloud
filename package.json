{
  "name": "homebridge-daikin-tempsensor-nocloud",
  "version": "1.4.7",
  "description": "Provides temperature sensor for HomeKit as plugin for homebridge: https://github.com/nfarina/homebridge",
  "license": "MIT",
  "keywords": [
    "homebridge-plugin",
    "daikin"
  ],
  "engines": {
    "homebridge": "^1.10.0 || ^2.0.0-beta.0",
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0"
  },
  "author": "Christian Brandlehner",
  "contributors": [
    "Pierre-Julien Cazaux",
    "greensouth",
    "Fred de Gier",
    "Fabian Leutgeb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbrandlehner/homebridge-daikin-tempsensor-nocloud.git"
  },
  "dependencies": {
    "superagent": "^10.2.3",
    "ws": "^8.18.0"
  },
  "bugs": {
    "url": "https://github.com/cbrandlehner/homebridge-daikin-tempsensor-nocloud/issues"
  },
  "homepage": "https://github.com/cbrandlehner/homebridge-daikin-tempsensor-nocloud#readme",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cbrandlehner"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/CBrandlehner"
    }
  ],
  "main": "src/index.js",
  "scripts": {
    "lint:json": "eslint .",
    "test": "node --test",
    "pretest": "npm run lint:json",
    "dev": "npx homebridge -P . -U ./test -D",
    "dev:live": "bash -c 'cp test/config.live.json test/config.json && npx homebridge -P . -U ./test -D'",
    "probe:device": "bash dev/probe-device.sh"
  },
  "devDependencies": {
    "@eslint/json": "^2.0.0",
    "eslint": "^10.0.0"
  }
